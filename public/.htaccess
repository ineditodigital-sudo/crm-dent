<IfModule mod_rewrite.c>
  RewriteEngine On

  # 1. Redirigir peticiones de API al backend Node.js (preservando el prefijo /api/)
  #    ANTES era: ^api/(.*) → localhost:3000/$1  ← BUG: quitaba el /api/
  #    CORRECTO:  ^(api/.*)  → localhost:3000/$1  ← mantiene /api/ en la URL
  RewriteCond %{REQUEST_URI} ^/api/
  RewriteRule ^(api/.*)$ http://localhost:3000/$1 [P,L]

  # 2. Redirigir peticiones a /uploads al backend Node.js
  RewriteCond %{REQUEST_URI} ^/uploads/
  RewriteRule ^(uploads/.*)$ http://localhost:3000/$1 [P,L]

  # 3. Soporte para React Router (SPA) — solo si el archivo no existe
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l
  RewriteRule . /index.html [L]
</IfModule>

# Aumentar límite de subida de archivos vía PHP (por si Passenger lo filtra)
<IfModule mod_php8.c>
  php_value upload_max_filesize 10M
  php_value post_max_size 10M
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php83 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
